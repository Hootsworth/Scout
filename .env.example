# Scout local environment variables configuration
# Duplicate this file as '.env' and fill in the values below.

# Firebase user UID (can be copied from the Scout setup dashboard)
USER_UID=

# Target email to receive the weekly academic reviews
USER_EMAIL=

# Gemini API Key for analyzing email contents and writing summaries
GEMINI_API_KEY=

# SMTP credentials for sending emails (Brevo relay server)
BREVO_SMTP_LOGIN=
BREVO_SMTP_PASSWORD=

# Google OAuth Credentials (for accessing Gmail and Google Calendar APIs)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REFRESH_TOKEN=

# Optional: Path to Firebase admin credentials json file (default: firebase_key.json)
FIREBASE_KEY_PATH=firebase_key.json
